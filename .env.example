# ==============================================
# SELVA IMPORT - Variables de Entorno
# ==============================================
# Copia este archivo a .env y completa los valores

# Entorno (development o production)
NODE_ENV=production

# Base de datos PostgreSQL
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/selva_import

# Secreto para sesiones (genera uno seguro con: openssl rand -hex 32)
SESSION_SECRET=tu_secreto_seguro_aqui

# Puerto del servidor (opcional, por defecto 5000)
PORT=5000

# URL pública del sitio (usada en sitemap.xml y meta tags)
# SITE_URL=https://selvaimport.onrender.com

# Cookie segura (true por defecto en produccion con HTTPS)
# Pon "false" si ejecutas produccion sin HTTPS (ej: detras de un proxy sin SSL)
# COOKIE_SECURE=false

# Credenciales del administrador inicial (REQUERIDO en produccion)
ADMIN_EMAIL=admin@selvaimport.com
ADMIN_PASSWORD=cambia_esta_contraseña

# Cloudinary (subida de imagenes)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# WhatsApp (numero con codigo de pais, sin +)
# NOTA: Se incluye en el build del frontend. Recompila con npm run build si lo cambias.
VITE_WHATSAPP_NUMBER=51998130656

# ── Telegram (opcional, para notificaciones de pedidos) ──
# TELEGRAM_BOT_TOKEN=tu_token_del_bot
# TELEGRAM_CHAT_ID=tu_chat_id

# ── Google OAuth (opcional, para login con Google) ──
# GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
